{
  "name": "agentic-ide",
  "version": "1.0.0",
  "description": "AI-powered extensible IDE with visual workflow automation",
  "author": "Agentic Team",
  "license": "MIT",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "electron:dev": "concurrently \"vite\" \"npm run electron:watch\"",
    "electron:build": "bun run build && electron-builder",
    "electron:build:win": "bun run build && electron-builder --win",
    "electron:build:mac": "bun run build && electron-builder --mac",
    "electron:build:linux": "bun run build && electron-builder --linux",
    "preview": "vite preview",
    "start": "vite"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.0.0",
    "@anthropic-ai/sdk": "^0.30.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@monaco-editor/react": "^4.6.0",
    "ai": "^4.0.0",
    "flexlayout-react": "^0.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.0",
    "reactflow": "^11.11.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "bun-types": "^1.0.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  },
  "build": {
    "appId": "com.agentic.ide",
    "productName": "Agentic IDE",
    "npmRebuild": false,
    "directories": {
      "output": "dist-build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "asar": false,
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": ["x64"]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}